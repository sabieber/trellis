# Copy this file to `.env` and fill in the values before running the app.
# `.env` is gitignored; docker compose loads it automatically.

# --- Database ---
# Postgres credentials. POSTGRES_USER doubles as the database name.
POSTGRES_USER=trellis
POSTGRES_PASSWORD=change-me

# Connection string used by the backend.
# For host-side tooling (e.g. `cargo run`, the diesel CLI) use `localhost`.
# Docker Compose overrides this to use the `db` service host automatically.
DATABASE_URL=postgres://trellis:change-me@localhost:5432/trellis

# --- Auth ---
# Secret used to sign JWTs. Use a long, random value in production.
JWT_SECRET=change-me

# --- External services ---
# Google Books API key (https://console.cloud.google.com/apis/credentials).
GOOGLE_BOOKS_API_KEY=your-google-books-api-key
